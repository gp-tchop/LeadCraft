# Server
PORT=3001
NODE_ENV=development

# Redis (required for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Apollo API
APOLLO_API_KEY=your_apollo_api_key_here

# Hunter.io API
HUNTER_API_KEY=your_hunter_api_key_here

# RocketReach API
ROCKETREACH_API_KEY=your_rocketreach_api_key_here

# Clay API (webhook URL or API key)
CLAY_API_KEY=your_clay_api_key_here
CLAY_WEBHOOK_URL=

# Email Verification (optional - e.g. ZeroBounce, NeverBounce)
EMAIL_VERIFY_API_KEY=

# Enrichment settings
ENRICHMENT_MODE=sequential
# Options: sequential | parallel
# sequential = try providers one by one with fallback
# parallel   = query all providers at once, pick best result

MAX_CONCURRENT_ROWS=10
# How many rows to process in parallel

PROVIDER_TIMEOUT_MS=15000
# Timeout for each provider API call

UPLOAD_MAX_SIZE_MB=50
